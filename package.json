  "description": "Unified MCP server for prediction markets — Kalshi, Polymarket, Limitless behind one normalized tool surface.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "allbets-mcp": "dist/index.js"
  },
  "scripts": {
